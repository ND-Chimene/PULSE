<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">
		<title>
			{% block title %}Dashboard
				{{title}}
				- PULSE
			{% endblock %}
		</title>
		<link rel="icon" href="{{ asset('build/images/icon.webp') }}" type="image/png">
		{% block stylesheets %}
			{{ encore_entry_link_tags('app') }}
		{% endblock %}

		{% block javascripts %}
			{{ encore_entry_script_tags('app') }}
		{% endblock %}
		<script src="{{ asset('js/chart.min.js') }}"></script>
	</head>

	<body>
		{% block body %}
			{% if app.request.get('_route') != 'app_login' %}
				<section class="bg-black-to-red h-screen p-6 overflow-hidden">
					<div class="flex flex-row gap-8 h-full">

						{% include '_partials/header.html.twig' %}

						<main class="flex-1 min-w-0 bg-primary-white rounded-2xl drop-shadow-lg p-10 flex flex-col overflow-hidden">
							<div class="flex-shrink-0 w-full flex flex-row justify-between items-center">
								<h1 class="text-2xl font-semibold">Bienvenue
									{{app.user.lastname}}</h1>
								<div class="flex flex-row gap-4 items-center justify-center">
									<div class="h-12 w-auto flex flex-row gap-x-2 items-center justify-center text-xl">
										<p id="clock">
											{{ "now" | date("d/m/Y H:i", "Europe/Paris") }}
										</p>
									</div>
									<div class="h-10 w-auto bg-secondary-black text-primary-white rounded-2xl flex flex-row gap-x-2 items-center justify-center px-4">
										<span class="w-6 h-6">
											<img src="{{ asset('build/icons/person.svg') }}" class="w-full h-full object-contain" alt="Icon Person">
										</span>
										<p class="text-sm">
											{{ app.user.lastname }}
										</p>
									</div>
								</div>
							</div>

							<section class="flex-1 min-h-0  pt-6 flex flex-col gap-2">

								<h2 class="text-2xl font-semibold">Dashboard
									{{title}}
								</h2>

								{{ block('page_content') }}
							</section>

						</main>
					</div>
				</section>
			{% endif %}
		{% endblock %}

		{% block login_content %}{% endblock %}
	</body>
</html></body></html>
