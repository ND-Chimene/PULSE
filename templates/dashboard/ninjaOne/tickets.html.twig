{% set colors = ['#E74C3C', '#FFCE56', '#3498DB', '#95A5A6'] %}
{% block page_content %}
	<section class="bg-primary-white rounded-lg p-6 shadow-md flex flex-col items-center h-full">
		<section class="flex flex-row items-center gap-5 w-full my-5">
			<span class="h-9 w-auto p-1.5 flex items-center justify-center bg-secondary-red rounded-lg ">
				<img src="{{ asset('build/icons/assignment.svg') }}" class="w-full h-full object-contain" alt="Icon Assignment">
			</span>
			<h3 class="text-2xl">État des tickets</h3>
		</section>

		<section class="flex flex-col items-center justify-center w-full h-full gap-x-5">
			<div class="w-1/2 h-full flex flex-col items-center justify-center gap-10">
				<p class="flex items-center justify-center text-lg gap-2">
					<span class="text-4xl font-semibold">
						{{openTicketCounts}}
					</span>
					Tickets Non Résolus
				</p>
			</div>
			<div class="h-full w-full flex flex-col items-center justify-center">
				<canvas id="ticketsChart" class="h-40 aspect-square mb-5"></canvas>
				<div class="flex flex-row items-center justify-center gap-5 flex-wrap">
					{% for status in statusTickets %}
						<div class="flex items-center justify-start gap-2">
							<span class="h-4 aspect-square rounded-full" style="background-color: {{ colors[loop.index0 % colors|length] }};"></span>
							<p>{{ status }}</p>
						</div>
					{% endfor %}
				</div>
			</div>
		</section>

		<script>
			document.addEventListener('DOMContentLoaded', () => {
				const ticketsChart = document.getElementById('ticketsChart').getContext('2d');

				const config = {
					type: 'pie',
					data: { labels: {{ statusTicketsJson|raw }},
					datasets: [{
						label: 'État des tickets',
						data: {{ ticketCountsJson|raw }},
						backgroundColor: {{ colors|json_encode|raw }},
						hoverOffset: 4
						}]
					},
					options: {
					responsive: false,
					plugins: { legend: { display: false } }
					}
				};
				new Chart(ticketsChart, config);
				});
		</script>
	</section>
{% endblock %}
