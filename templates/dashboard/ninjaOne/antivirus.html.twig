{% block page_content %}
	<section class="bg-primary-white rounded-lg p-6 shadow-md flex flex-col items-center justify-start h-full">
		<section class="flex flex-row items-center gap-5 w-full my-5">
			<span class="h-9 w-auto p-1.5 flex items-center justify-center bg-secondary-red rounded-lg ">
				<img src="{{ asset('build/icons/shield.svg') }}" class="w-full h-full object-contain" alt="Icon Shield">
			</span>
			<h3 class="text-2xl">Antivirus</h3>
		</section>

		<section class="w-full h-32">
			<div class="overflow-y-scroll">
				{% if statusAntivirus is defined and statusAntivirus|length > 0 %}
					{% for i in 0..(statusAntivirus|length - 1) %}
						<div class="p-2 bg-secondary-red rounded-lg text-primary-white mb-5">
							<p>
								{{ statusAntivirus[i] }}
							</p>
						</div>
					{% endfor %}
				{% else %}
					<div class="text-gray-500 text-center mt-10">Aucun antivirus détecté.</div>
				{% endif %}
			</div>
		</section>
	</section>
{% endblock %}
