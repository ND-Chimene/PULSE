{% block page_content %}
<h3>Antivirus</h3>
    {% if statusAntivirus is defined and statusAntivirus is not empty and antivirusCounts is defined and antivirusCounts is not empty %}
        <div class="grid grid-cols-4 gap-4">
            {% for i in 0..statusAntivirus|length - 1 %}
                <div class="p-4 bg-white rounded-lg shadow">
                    <h3 class="font-bold">{{ statusAntivirus[i] }}</h3>
                    <p class="text-2xl">{{ antivirusCounts[i] }}</p>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="p-4 bg-white rounded-lg shadow">
            <h3 class="font-bold">Aucune alerte disponible</h3>
        </div>
    {% endif %}
{% endblock %}