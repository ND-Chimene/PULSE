{% extends 'base.html.twig' %}

{% block title %}Gestion des utilisateurs - PULSE{% endblock %}

{% block page_content %}
    <section class="flex flex-col gap-4 flex-1 min-h-0">

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="flash-{{ label }} p-4 rounded-lg text-sm flex-shrink-0">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        <section class="bg-secondary-white rounded-xl flex-1 flex flex-col overflow-hidden">

            <div class="flex items-center justify-between px-8 py-6 border-b border-gray-100 flex-shrink-0">
                <div>
                    <p class="text-sm text-gray-500">{{ users|length }} compte{{ users|length > 1 ? 's' : '' }} enregistré{{ users|length > 1 ? 's' : '' }}</p>
                </div>
                <a href="{{ path('app_admin_create_user') }}"
                   class="bg-primary-black text-primary-white text-sm font-medium rounded-lg px-5 py-2 hover:bg-secondary-black transition-all duration-300">
                    + Créer un compte
                </a>
            </div>

            <div class="overflow-y-auto flex-1">
                <table class="w-full">
                    <thead class="bg-gray-50 sticky top-0">
                        <tr>
                            <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-8 py-3">Nom</th>
                            <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Email</th>
                            <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Rôle</th>
                            <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Créé le</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        {% for user in users %}
                            <tr class="hover:bg-gray-50 transition-colors duration-150">
                                <td class="px-8 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-8 h-8 rounded-full bg-primary-black text-primary-white flex items-center justify-center text-xs font-semibold flex-shrink-0">
                                            {{ user.firstname|first|upper }}{{ user.lastname|first|upper }}
                                        </div>
                                        <span class="text-sm font-medium">{{ user.fullname }}</span>
                                    </div>
                                </td>
                                <td class="px-4 py-4 text-sm text-gray-600">{{ user.email }}</td>
                                <td class="px-4 py-4">
                                    {% for role in user.roles %}
                                        {% if role != 'ROLE_USER' %}
                                            <span class="inline-block text-xs font-medium px-2 py-1 rounded-full
                                                {{ role == 'ROLE_ADMIN' ? 'bg-black text-white' : 'bg-gray-100 text-gray-700' }}">
                                                {{ role == 'ROLE_ADMIN' ? 'Admin' : 'Technicien IT' }}
                                            </span>
                                        {% endif %}
                                    {% endfor %}
                                </td>
                                <td class="px-4 py-4 text-sm text-gray-500">
                                    {{ user.createdAt|date('d/m/Y') }}
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="4" class="text-center py-12 text-gray-400 text-sm">Aucun utilisateur enregistré.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

        </section>
    </section>
{% endblock %}
